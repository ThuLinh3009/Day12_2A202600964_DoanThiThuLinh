# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Shopping Assistant API
APP_VERSION=1.0.0

# ── LLM Provider (Day 09 Shopping Agent) ─────────────────────────────────────
# Chọn 1 trong các provider bên dưới:

# Option 1: Google Gemini (khuyến nghị — có free tier)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash-lite
GOOGLE_API_KEY=your-google-api-key-here

# Option 2: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your-openai-key-here

# Option 3: OpenRouter (nhiều model, có free tier)
# LLM_PROVIDER=openrouter
# LLM_MODEL=deepseek/deepseek-chat
# OPENROUTER_API_KEY=your-openrouter-key-here

# ── Security — BẮT BUỘC thay trong production ────────────────────────────────
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# ── Rate & Budget ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
DAILY_BUDGET_USD=10.0

# ── Storage ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── RAG Settings (Optional) ───────────────────────────────────────────────────
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RAG_TOP_K=4
